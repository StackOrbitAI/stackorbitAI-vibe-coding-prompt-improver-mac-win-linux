{
  "name": "stackorbitai-vibe-coding-prompt-improver",
  "version": "1.0.19",
  "description": "Vibe Coding Prompt Improver desktop utility",
  "main": "dist/main/index.js",
  "author": "StackOrbitAI <support@stackorbitai.com>",
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build:renderer": "vite build --config vite.config.ts",
    "build:main": "tsup src/main/index.ts src/main/preload.ts --out-dir dist/main --format cjs --external electron",
    "build": "npm run build:renderer && npm run build:main",
    "package": "npm run build && electron-builder --win --mac --linux",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac",
    "package:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "framer-motion": "^11.2.10",
    "lucide-react": "^0.395.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "electron": "^30.1.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  },
  "build": {
    "appId": "com.stackorbitai.vibe-coding-prompt-improver",
    "productName": "stackorbitai-vibe-coding-prompt-improver",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "build/**/*",
      "package.json"
    ],

    "asar": true,
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "artifactName": "Vibe-Prompt-Improver-Mac-v${version}-${arch}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "artifactName": "Vibe-Prompt-Improver-Windows-v${version}-${arch}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "artifactName": "Vibe-Prompt-Improver-Linux-v${version}-${arch}.${ext}",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "shortcutName": "Vibe Coding Prompt Improver",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "artifactName": "Vibe-Prompt-Improver-Windows-v${version}-${arch}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "StackOrbitAI",
      "repo": "stackorbitAI-vibe-coding-prompt-improver-mac-win-linux",
      "private": false
    }
  }
}